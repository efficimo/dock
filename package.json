{
  "name": "@efficimo/dock",
  "version": "0.1.0",
  "description": "Detach any React panel into its own browser window — reactive, persistent, router-agnostic.",
  "author": "efficimo",
  "license": "MIT",
  "keywords": [
    "react",
    "panel",
    "dock",
    "detach",
    "window",
    "observable",
    "pwa"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/efficimo/dock.git"
  },
  "bugs": {
    "url": "https://github.com/efficimo/dock/issues"
  },
  "homepage": "https://efficimo.github.io/dock/",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "npm run dev --prefix demo",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome ci --error-on-warnings .",
    "format": "biome check --write .",
    "install:demo": "npm install --prefix demo",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "@efficimo/observable": ">=0.1.0",
    "@efficimo/storage": ">=0.1.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.0.0"
  }
}
